Depois: consulta a tabela voos (COM DADOS)
const [ano, mes] = anoMes.split('-');
const dataInicio = `${ano}-${mes}-01`;
const ultimoDia = new Date(ano, mes, 0).getDate();
const dataFim = `${ano}-${mes}-${ultimoDia}`;
const dados = await sbFetch(`voos?data_referencia=gte.${dataInicio}&data_referencia=lte.${dataFim}&or=(icao_origem.eq.${icao},icao_destino.eq.${icao})...`);


